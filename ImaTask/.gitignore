# ====================================================================
# Google Apps Script (clasp) 関連
# ====================================================================
# scriptId など、フォークしたユーザーが自分の値に書き換えるべき設定
.clasp.json
# clasp のローカル認証情報 (万一プロジェクト直下に置かれた場合の保険)
.clasprc.json

# ====================================================================
# デプロイ用スクリプト (Deployment ID を含むため公開しない)
# テンプレートとして deploy.sample.bat を別途配置する想定
# ====================================================================
deploy.bat

# ====================================================================
# OS / エディタが生成するファイル
# ====================================================================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.directory
.Trash-*

# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml

# ====================================================================
# ログ・一時ファイル・バックアップ
# ====================================================================
*.log
*.bak
*.backup
*.tmp
*.orig

# ====================================================================
# 環境変数・秘密情報
# ====================================================================
.env
.env.*
*.pem
*.key
credentials.json
secrets.json

# ====================================================================
# Node.js (将来 clasp 依存などを入れた場合に備えて)
# ====================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
