# data/jma/ は気象庁ページ・AMeDAS APIのローカルキャッシュ
data/

# ============================================================
# Python（scripts/ 内のバックフィルツール用）
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
env/
.python-version

# ============================================================
# OS / エディタ
# ============================================================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/

# ============================================================
# 環境変数・認証情報（誤コミット防止）
# ============================================================
.env
.env.*
*.pem
*.key
credentials.json
client_secret*.json
service-account*.json

# ============================================================
# clasp（GAS CLI を使う場合）
# ============================================================
.clasp.json
.clasprc.json

# ============================================================
# ログ・一時ファイル
# ============================================================
*.log
*.tmp
*.bak
